{
  "name": "@neox/remotion-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Render-only Remotion engine. Stream-typed timeline kernel.",
  "type": "module",
  "main": "./src/lite.entry.tsx",
  "exports": {
    ".": "./src/lite.entry.tsx",
    "./lite": "./src/lite.entry.tsx",
    "./full": "./src/full.entry.tsx",
    "./player": "./src/player.entry.tsx",
    "./schema": "./src/schema/index.ts",
    "./components": "./src/components/index.ts",
    "./themes": "./src/themes/index.tsx",
    "./templates": "./src/templates/index.ts",
    "./scenes": "./src/scenes/index.ts",
    "./remotion": "./src/remotion.config.ts"
  },
  "scripts": {
    "render": "node src/render/cli.mjs render",
    "render:all": "node src/render/cli.mjs render --aspect all",
    "render:demo": "node src/render/cli.mjs render src/demo-components.json --aspect all",
    "templates": "node src/render/cli.mjs templates",
    "preview": "node src/render/cli.mjs preview",
    "render:pixelle": "remotion render examples/pixelle/index.tsx Root out/pixelle-asset-default.mp4 --props=./examples/pixelle/asset-default.json",
    "render:gallery": "remotion render examples/pixelle/index.tsx Root out/pixelle-gallery.mp4 --props=./examples/pixelle/gallery.json",
    "studio": "remotion studio src/remotion.config.ts",
    "studio:demo": "remotion studio src/remotion.config.ts --props=./src/demo-components.json",
    "studio:pixelle": "remotion studio examples/pixelle/remotion.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@remotion/cli": "4.0.469",
    "@remotion/media-parser": "4.0.469",
    "@remotion/media-utils": "4.0.469",
    "@remotion/player": "^4.0.469",
    "@remotion/transitions": "4.0.469",
    "immer": "^10.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "4.0.469",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
