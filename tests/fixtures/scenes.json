{
  "id": "root",
  "type": "root",
  "width": 640,
  "height": 480,
  "fps": 30,
  "isSeries": true,
  "transition": "fade",
  "transitionTime": 0.3,
  "theme": "cinematic",
  "children": [
    {
      "id": "scene-1",
      "type": "scene",
      "name": "Intro",
      "description": "Opening hook with headline animation",
      "children": [
        {
          "id": "scene-1-bg",
          "type": "component",
          "componentName": "GradientBackground",
          "props": { "type": "radial", "animated": true },
          "isBackground": true,
          "actions": [{ "start": 0, "end": 3 }]
        },
        {
          "id": "scene-1-headline",
          "type": "component",
          "componentName": "BigStatement",
          "props": {
            "headline": "Scene Rendering Works",
            "subhead": "Testing the scene type in stream tree"
          },
          "actions": [{ "start": 0, "end": 3 }]
        }
      ]
    },
    {
      "id": "scene-2",
      "type": "scene",
      "name": "Conclusion",
      "description": "Final message",
      "children": [
        {
          "id": "scene-2-headline",
          "type": "component",
          "componentName": "BigStatement",
          "props": {
            "headline": "Test Complete",
            "subhead": "All scene types render correctly"
          },
          "actions": [{ "start": 0, "end": 2 }]
        }
      ]
    }
  ]
}
