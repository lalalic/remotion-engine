              "words": [
                { "text": "Karaoke", "start": 0, "end": 1.25 },
                { "text": "word", "start": 1.25, "end": 2.5 },
                { "text": "highlight", "start": 2.5, "end": 3.75 },
                { "text": "works", "start": 3.75, "end": 5 }
              ]
            }
          ],
          "fontSize": 48,
          "actions": [{ "start": 0, "end": 5 }]
        }
