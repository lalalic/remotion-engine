          "actions": [{ "start": 0, "end": 4 }]
        },
        {
          "id": "inline-caption",
          "type": "subtitle",
          "src": "Inline subtitle text works",
          "fontSize": 48,
          "style": "color: #ffffff; text-shadow: 0 4px 20px rgba(0,0,0,0.8);",
          "actions": [{ "start": 0.3, "end": 3.7 }]
        }
      ]
    },
    {
      "id": "scene-2",
      "type": "folder",
      "isSeries": false,
      "children": [
        {
          "id": "bg2",
          "type": "image",
          "src": "https://picsum.photos/seed/sub2/640/480",
          "fit": "cover",
          "actions": [{ "start": 0, "end": 4 }]
        },
        {
          "id": "vtt-caption",
          "type": "subtitle",
          "src": "WEBVTT\n\n00:00:00.500 --> 00:00:02.000\nVTT subtitle renders\n\n00:00:02.500 --> 00:00:04.000\nSecond VTT cue",
