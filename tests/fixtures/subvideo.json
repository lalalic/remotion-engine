{
  "id": "root",
  "type": "root",
  "width": 640,
  "height": 480,
  "fps": 30,
  "isSeries": true,
  "transition": "fade",
  "transitionTime": 0.3,
  "children": [
    {
      "id": "intro",
      "type": "folder",
      "isSeries": false,
      "children": [
        {
          "id": "bg-intro",
          "type": "image",
          "src": "https://picsum.photos/seed/subv-intro/640/480",
          "fit": "cover",
          "actions": [{ "start": 0, "end": 2 }]
        },
        {
          "id": "title-intro",
          "type": "subtitle",
          "src": "Main Video",
          "fontSize": 48,
          "style": "color: #ffffff; font-weight: bold;",
          "actions": [{ "start": 0, "end": 2 }]
        }
      ]
    },
    {
      "id": "subvideo-chapter",
      "type": "include",
      "name": "Embedded Reel",
      "src": "data:application/json;base64,",
      "actions": [{ "start": 0, "end": 4 }]
    },
    {
      "id": "outro",
      "type": "folder",
      "isSeries": false,
      "children": [
        {
          "id": "bg-outro",
          "type": "image",
          "src": "https://picsum.photos/seed/subv-outro/640/480",
          "fit": "cover",
          "actions": [{ "start": 0, "end": 2 }]
        },
        {
          "id": "title-outro",
          "type": "subtitle",
          "src": "Back to Main",
          "fontSize": 48,
          "style": "color: #ffffff; font-weight: bold;",
          "actions": [{ "start": 0, "end": 2 }]
        }
      ]
    }
  ]
}
