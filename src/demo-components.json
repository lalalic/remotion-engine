{
  "id": "root",
  "type": "root",
  "width": 1920,
  "height": 1080,
  "fps": 30,
  "theme": "cinematic",
  "isSeries": true,
  "transition": "fade",
  "transitionTime": 0.5,
  "children": [
    {
      "id": "bgm",
      "type": "audio",
      "src": "assets/bgm/cinematic-epic.mp3",
      "volume": 0.2,
      "actions": [{ "start": 0, "end": 27 }]
    },
    {
      "id": "scene-1",
      "type": "folder",
      "isSeries": false,
      "children": [
        {
          "id": "sfx-impact",
          "type": "audio",
          "src": "assets/sfx/impact.mp3",
          "volume": 0.7,
          "actions": [{ "start": 0.3, "end": 1 }]
        },
        {
          "id": "bg-gradient",
          "type": "component",
          "componentName": "GradientBackground",
          "props": { "type": "radial", "animated": true, "noise": true },
          "isBackground": true,
          "actions": [{ "start": 0, "end": 6 }]
        },
        {
          "id": "particles",
          "type": "component",
          "componentName": "ParticleField",
          "props": { "count": 50, "speed": 0.4 },
          "isBackground": true,
          "actions": [{ "start": 0, "end": 6 }]
        },
        {
          "id": "headline",
          "type": "component",
          "componentName": "AnimatedHeadline",
          "props": {
            "text": "Describe it. Done.",
            "subtext": "The AI-powered document engine",
            "gradient": true,
            "glow": true
          },
          "actions": [{ "start": 0, "end": 6 }]
        }
      ]
    },
    {
      "id": "scene-2",
      "type": "folder",
      "isSeries": false,
      "children": [
        {
          "id": "sfx-whoosh-2",
          "type": "audio",
          "src": "assets/sfx/whoosh.mp3",
          "volume": 0.5,
          "actions": [{ "start": 0, "end": 0.5 }]
        },
        {
          "id": "bg2",
          "type": "component",
          "componentName": "GradientBackground",
          "props": { "type": "linear", "animated": true },
          "isBackground": true,
          "actions": [{ "start": 0, "end": 8 }]
        },
        {
          "id": "mockup",
          "type": "component",
          "componentName": "DeviceMockup",
          "props": {
            "device": "browser",
            "src": "https://picsum.photos/seed/demo/1920/1080",
            "title": "app.example.com",
            "shadow": true
          },
          "actions": [{ "start": 0, "end": 8 }]
        },
        {
          "id": "light-leak",
          "type": "component",
          "componentName": "LightLeak",
          "props": { "intensity": 0.3 },
          "actions": [{ "start": 0, "end": 8 }]
        }
      ]
    },
    {
      "id": "scene-3",
      "type": "folder",
      "isSeries": false,
      "children": [
        {
          "id": "sfx-click",
          "type": "audio",
          "src": "assets/sfx/click.mp3",
          "volume": 0.6,
          "actions": [{ "start": 0, "end": 0.3 }]
        },
        {
          "id": "bg3",
          "type": "component",
          "componentName": "GradientBackground",
          "props": { "type": "radial", "animated": true, "noise": true },
          "isBackground": true,
          "actions": [{ "start": 0, "end": 5 }]
        },
        {
          "id": "stat",
          "type": "component",
          "componentName": "StatCounter",
          "props": {
            "value": 200,
            "suffix": "+",
            "label": "screens generated per hour"
          },
          "actions": [{ "start": 0, "end": 5 }]
        }
      ]
    },
    {
      "id": "scene-4",
      "type": "folder",
      "isSeries": false,
      "children": [
        {
          "id": "sfx-transition",
          "type": "audio",
          "src": "assets/sfx/transition.mp3",
          "volume": 0.5,
          "actions": [{ "start": 0, "end": 0.8 }]
        },
        {
          "id": "bg4",
          "type": "component",
          "componentName": "GradientBackground",
          "props": { "type": "conic", "animated": true },
          "isBackground": true,
          "actions": [{ "start": 0, "end": 5 }]
        },
        {
          "id": "glitch",
          "type": "component",
          "componentName": "GlitchReveal",
          "props": { "text": "THE FUTURE IS NOW", "intensity": 0.8 },
          "actions": [{ "start": 0, "end": 5 }]
        }
      ]
    },
    {
      "id": "scene-5",
      "type": "folder",
      "isSeries": false,
      "children": [
        {
          "id": "sfx-typing",
          "type": "audio",
          "src": "assets/sfx/typing.mp3",
          "volume": 0.4,
          "actions": [{ "start": 0.5, "end": 3 }]
        },
        {
          "id": "bg5",
          "type": "component",
          "componentName": "GradientBackground",
          "props": { "type": "linear", "animated": true, "noise": true },
          "isBackground": true,
          "actions": [{ "start": 0, "end": 5 }]
        },
        {
          "id": "typewriter",
          "type": "component",
          "componentName": "TypewriterText",
          "props": { "text": "npm install @neox/remotion-engine\n\n> Rendering complete. 3 videos exported.", "speed": 25 },
          "actions": [{ "start": 0, "end": 5 }]
        }
      ]
    }
  ]
}
