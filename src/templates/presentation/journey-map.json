{
  "id": "journey-map",
  "name": "Journey Map",
  "description": "Animated route visualization with waypoint stops. Each waypoint fades in with a title card and stat. Uses the map stream type for route animation. Perfect for travel vlogs, product roadmaps, delivery routes, conference recaps.",
  "category": "presentation",
  "aspects": ["16x9", "9x16", "1x1"],
  "duration": 20,
  "theme": "cinematic",
  "slots": [
    { "name": "headline", "type": "text", "label": "Journey title", "required": true, "default": "Our Journey" },
    { "name": "tagline", "type": "text", "label": "Subtitle", "default": "From idea to reality" },
    { "name": "stop1Label", "type": "text", "label": "Stop 1 name", "required": true, "default": "Start" },
    { "name": "stop1Lat", "type": "number", "label": "Stop 1 latitude", "default": 37.7749 },
    { "name": "stop1Lng", "type": "number", "label": "Stop 1 longitude", "default": -122.4194 },
    { "name": "stop1Stat", "type": "text", "label": "Stop 1 metric", "default": "Day 1" },
    { "name": "stop2Label", "type": "text", "label": "Stop 2 name", "required": true, "default": "Milestone" },
    { "name": "stop2Lat", "type": "number", "label": "Stop 2 latitude", "default": 36.7783 },
    { "name": "stop2Lng", "type": "number", "label": "Stop 2 longitude", "default": -119.4179 },
    { "name": "stop2Stat", "type": "text", "label": "Stop 2 metric", "default": "Day 30" },
    { "name": "stop3Label", "type": "text", "label": "Stop 3 name", "required": true, "default": "Destination" },
    { "name": "stop3Lat", "type": "number", "label": "Stop 3 latitude", "default": 34.0522 },
    { "name": "stop3Lng", "type": "number", "label": "Stop 3 longitude", "default": -118.2437 },
    { "name": "stop3Stat", "type": "text", "label": "Stop 3 metric", "default": "Day 90" },
    { "name": "routeColor", "type": "color", "label": "Route color", "default": "#4285F4" },
    { "name": "endStat", "type": "number", "label": "Final metric", "default": 1000 },
    { "name": "endStatSuffix", "type": "text", "label": "Final metric suffix", "default": "+" },
    { "name": "endStatLabel", "type": "text", "label": "Final metric label", "default": "miles traveled" },
    { "name": "cta", "type": "text", "label": "Closing line", "required": true, "default": "The journey continues →" }
  ],
  "streamTree": {
    "id": "root",
    "type": "root",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "theme": "${theme}",
    "isSeries": true,
    "transition": "fade",
    "transitionTime": 0.4,
    "stylesheet": ".effect { overflow: hidden; }",
    "children": [
      {
        "id": "scene-title",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "title-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          { "id": "title-particles", "type": "component", "componentName": "ParticleField", "props": { "count": 60, "speed": 0.3 }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          {
            "id": "title-fx",
            "type": "effect",
            "animation": "fadeInDown",
            "children": [
              { "id": "title-text", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${headline}", "size": "xxl", "gradient": true, "glow": true }, "actions": [{ "start": 0.3, "end": 4 }] }
            ],
            "actions": [{ "start": 0.3, "end": 4 }]
          },
          { "id": "title-sub", "type": "component", "componentName": "TypewriterText", "props": { "text": "${tagline}", "speed": 40 }, "actions": [{ "start": 1.5, "end": 4 }] }
        ]
      },
      {
        "id": "scene-route",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "route-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true, "noise": true }, "isBackground": true, "actions": [{ "start": 0, "end": 8 }] },
          {
            "id": "route-map",
            "type": "map",
            "waypoints": [
              { "lat": "${stop1Lat}", "lng": "${stop1Lng}", "label": "${stop1Label}" },
              { "lat": "${stop2Lat}", "lng": "${stop2Lng}", "label": "${stop2Label}" },
              { "lat": "${stop3Lat}", "lng": "${stop3Lng}", "label": "${stop3Label}" }
            ],
            "routeColor": "${routeColor}",
            "routeWeight": 5,
            "zoom": 8,
            "actions": [{ "start": 0, "end": 8 }]
          },
          {
            "id": "stop1-fx",
            "type": "effect",
            "animation": "fadeInUp",
            "children": [
              { "id": "stop1-card", "type": "component", "componentName": "TypewriterText", "props": { "text": "${stop1Label} — ${stop1Stat}", "speed": 50 }, "actions": [{ "start": 0.5, "end": 3 }] }
            ],
            "actions": [{ "start": 0.5, "end": 3 }]
          },
          {
            "id": "stop2-fx",
            "type": "effect",
            "animation": "fadeInUp",
            "children": [
              { "id": "stop2-card", "type": "component", "componentName": "TypewriterText", "props": { "text": "${stop2Label} — ${stop2Stat}", "speed": 50 }, "actions": [{ "start": 3, "end": 5.5 }] }
            ],
            "actions": [{ "start": 3, "end": 5.5 }]
          },
          {
            "id": "stop3-fx",
            "type": "effect",
            "animation": "fadeInUp",
            "children": [
              { "id": "stop3-card", "type": "component", "componentName": "TypewriterText", "props": { "text": "${stop3Label} — ${stop3Stat}", "speed": 50 }, "actions": [{ "start": 5.5, "end": 8 }] }
            ],
            "actions": [{ "start": 5.5, "end": 8 }]
          }
        ]
      },
      {
        "id": "scene-finale",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "fin-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true, "noise": true }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          { "id": "fin-leak", "type": "component", "componentName": "LightLeak", "props": { "intensity": 0.8 }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          { "id": "fin-particles", "type": "component", "componentName": "ParticleField", "props": { "count": 100, "speed": 0.5 }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          {
            "id": "fin-stat-fx",
            "type": "effect",
            "animation": "bounceIn",
            "children": [
              { "id": "fin-stat", "type": "component", "componentName": "StatCounter", "props": { "value": "${endStat}", "suffix": "${endStatSuffix}", "label": "${endStatLabel}" }, "actions": [{ "start": 0.3, "end": 4 }] }
            ],
            "actions": [{ "start": 0.3, "end": 4 }]
          }
        ]
      },
      {
        "id": "scene-cta",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "cta-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          {
            "id": "cta-fx",
            "type": "effect",
            "animation": "fadeInUp",
            "children": [
              { "id": "cta-text", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${cta}", "size": "xl", "gradient": true, "glow": true }, "actions": [{ "start": 0.3, "end": 4 }] }
            ],
            "actions": [{ "start": 0.3, "end": 4 }]
          }
        ]
      }
    ]
  }
}
