{
  "id": "before-after",
  "name": "Before & After",
  "description": "Problem → Solution comparison with slider",
  "category": "marketing",
  "aspects": ["16x9", "9x16", "1x1"],
  "duration": 23,
  "theme": "cinematic",
  "slots": [
    { "name": "problem", "type": "text", "label": "Problem headline", "required": true },
    { "name": "solution", "type": "text", "label": "Solution headline", "required": true },
    { "name": "before_screenshot", "type": "image", "label": "Before screenshot", "required": true },
    { "name": "after_screenshot", "type": "image", "label": "After screenshot", "required": true },
    { "name": "stat_value", "type": "number", "label": "Key metric value", "default": 95 },
    { "name": "stat_suffix", "type": "text", "label": "Metric suffix", "default": "%" },
    { "name": "stat_label", "type": "text", "label": "Metric label", "default": "improvement" },
    { "name": "cta", "type": "text", "label": "Call to action", "default": "See the difference" }
  ],
  "streamTree": {
    "id": "root",
    "type": "root",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "isSeries": true,
    "transition": "fade",
    "transitionTime": 0.6,
    "children": [
      {
        "id": "scene-problem",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-problem",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "linear", "colors": ["#1a0000", "#2d0000", "#ff000022"], "animated": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 5 }]
          },
          {
            "id": "problem-text",
            "type": "component",
            "componentName": "AnimatedHeadline",
            "props": { "text": "${problem}", "glow": true },
            "actions": [{ "start": 0, "end": 5 }]
          }
        ]
      },
      {
        "id": "scene-solution",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-solution",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "linear", "colors": ["#001a00", "#002d00", "#00ff0022"], "animated": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 5 }]
          },
          {
            "id": "solution-text",
            "type": "component",
            "componentName": "AnimatedHeadline",
            "props": { "text": "${solution}", "gradient": true, "glow": true },
            "actions": [{ "start": 0, "end": 5 }]
          }
        ]
      },
      {
        "id": "scene-compare",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-compare",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "radial", "animated": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 8 }]
          },
          {
            "id": "slider",
            "type": "component",
            "componentName": "ComparisonSlider",
            "props": {
              "before": "${before_screenshot}",
              "after": "${after_screenshot}",
              "beforeLabel": "Before",
              "afterLabel": "After"
            },
            "actions": [{ "start": 0, "end": 8 }]
          }
        ]
      },
      {
        "id": "scene-cta",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-cta",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "radial", "animated": true, "noise": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 5 }]
          },
          {
            "id": "stat",
            "type": "component",
            "componentName": "StatCounter",
            "props": {
              "value": "${stat_value}",
              "suffix": "${stat_suffix}",
              "label": "${stat_label}"
            },
            "actions": [{ "start": 0, "end": 5 }]
          }
        ]
      }
    ]
  }
}
