{
  "id": "social-clip",
  "name": "Social Clip",
  "description": "Short-form social content (15s) with stat and CTA",
  "category": "social",
  "aspects": ["9x16", "1x1", "16x9"],
  "duration": 15,
  "theme": "cinematic",
  "slots": [
    { "name": "headline", "type": "text", "label": "Hook headline", "required": true },
    { "name": "screenshot", "type": "image", "label": "Product shot", "required": true },
    { "name": "stat_value", "type": "number", "label": "Key metric", "default": 10 },
    { "name": "stat_suffix", "type": "text", "label": "Metric suffix", "default": "x" },
    { "name": "stat_label", "type": "text", "label": "Metric label", "default": "faster" },
    { "name": "cta", "type": "text", "label": "Call to action", "default": "Link in bio" }
  ],
  "streamTree": {
    "id": "root",
    "type": "root",
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "isSeries": true,
    "transition": "fade",
    "transitionTime": 0.3,
    "children": [
      {
        "id": "hook",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-hook",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "radial", "animated": true, "noise": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 4 }]
          },
          {
            "id": "hook-particles",
            "type": "component",
            "componentName": "ParticleField",
            "props": { "count": 30 },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 4 }]
          },
          {
            "id": "hook-text",
            "type": "component",
            "componentName": "GlitchReveal",
            "props": { "text": "${headline}", "intensity": 0.6 },
            "actions": [{ "start": 0, "end": 4 }]
          }
        ]
      },
      {
        "id": "demo",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-demo",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "linear", "animated": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 6 }]
          },
          {
            "id": "phone-mockup",
            "type": "component",
            "componentName": "DeviceMockup",
            "props": { "device": "phone", "src": "${screenshot}", "shadow": true },
            "actions": [{ "start": 0, "end": 6 }]
          }
        ]
      },
      {
        "id": "cta-scene",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-cta",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "radial", "animated": true, "noise": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 5 }]
          },
          {
            "id": "cta-stat",
            "type": "component",
            "componentName": "StatCounter",
            "props": {
              "value": "${stat_value}",
              "suffix": "${stat_suffix}",
              "label": "${stat_label}"
            },
            "actions": [{ "start": 0, "end": 5 }]
          }
        ]
      }
    ]
  }
}
