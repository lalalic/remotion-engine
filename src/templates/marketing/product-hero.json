{
  "id": "product-hero",
  "name": "Product Hero",
  "description": "Hero intro with animated headline, device mockup, and CTA",
  "category": "marketing",
  "aspects": ["16x9", "9x16", "1x1"],
  "duration": 19,
  "theme": "cinematic",
  "slots": [
    { "name": "headline", "type": "text", "label": "Main headline", "required": true },
    { "name": "subline", "type": "text", "label": "Subtitle", "default": "" },
    { "name": "screenshot", "type": "image", "label": "Product screenshot", "required": true },
    { "name": "appTitle", "type": "text", "label": "Browser tab title", "default": "localhost:3000" },
    { "name": "stat", "type": "number", "label": "Key metric", "default": 100 },
    { "name": "statSuffix", "type": "text", "label": "Metric suffix", "default": "+" },
    { "name": "statLabel", "type": "text", "label": "Metric label", "default": "screens generated" },
    { "name": "cta", "type": "text", "label": "Call to action", "default": "Try it now" }
  ],
  "streamTree": {
    "id": "root",
    "type": "root",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "theme": "${theme}",
    "isSeries": true,
    "transition": "fade",
    "transitionTime": 0.5,
    "children": [
      {
        "id": "scene-hero",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg1",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "radial", "animated": true, "noise": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 6 }]
          },
          {
            "id": "particles1",
            "type": "component",
            "componentName": "ParticleField",
            "props": { "count": 40, "speed": 0.3 },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 6 }]
          },
          {
            "id": "headline",
            "type": "component",
            "componentName": "AnimatedHeadline",
            "props": {
              "text": "${headline}",
              "subtext": "${subline}",
              "gradient": true,
              "glow": true
            },
            "actions": [{ "start": 0, "end": 6 }]
          }
        ]
      },
      {
        "id": "scene-demo",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg2",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "linear", "animated": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 8 }]
          },
          {
            "id": "mockup",
            "type": "component",
            "componentName": "DeviceMockup",
            "props": {
              "device": "browser",
              "src": "${screenshot}",
              "title": "${appTitle}",
              "shadow": true
            },
            "actions": [{ "start": 0, "end": 8 }]
          },
          {
            "id": "leak",
            "type": "component",
            "componentName": "LightLeak",
            "props": { "intensity": 0.25 },
            "actions": [{ "start": 0, "end": 8 }]
          }
        ]
      },
      {
        "id": "scene-cta",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg3",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "radial", "animated": true, "noise": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 5 }]
          },
          {
            "id": "cta-text",
            "type": "component",
            "componentName": "AnimatedHeadline",
            "props": {
              "text": "${cta}",
              "gradient": true,
              "glow": true,
              "split": "char"
            },
            "actions": [{ "start": 0, "end": 5 }]
          }
        ]
      }
    ]
  }
}
