{
  "id": "feature-showcase",
  "name": "Feature Showcase",
  "description": "Walk through 3 features with screenshots and descriptions",
  "category": "marketing",
  "aspects": ["16x9", "9x16", "1x1"],
  "duration": 31,
  "theme": "cinematic",
  "slots": [
    { "name": "headline", "type": "text", "label": "Intro headline", "required": true },
    { "name": "feature1_title", "type": "text", "label": "Feature 1 title", "required": true },
    { "name": "feature1_desc", "type": "text", "label": "Feature 1 description", "default": "" },
    { "name": "feature1_screenshot", "type": "image", "label": "Feature 1 screenshot", "required": true },
    { "name": "feature2_title", "type": "text", "label": "Feature 2 title", "required": true },
    { "name": "feature2_desc", "type": "text", "label": "Feature 2 description", "default": "" },
    { "name": "feature2_screenshot", "type": "image", "label": "Feature 2 screenshot", "required": true },
    { "name": "feature3_title", "type": "text", "label": "Feature 3 title", "required": true },
    { "name": "feature3_desc", "type": "text", "label": "Feature 3 description", "default": "" },
    { "name": "feature3_screenshot", "type": "image", "label": "Feature 3 screenshot", "required": true },
    { "name": "cta", "type": "text", "label": "Call to action", "default": "Get started today" }
  ],
  "streamTree": {
    "id": "root",
    "type": "root",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "isSeries": true,
    "transition": "slide",
    "transitionTime": 0.4,
    "children": [
      {
        "id": "intro",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-intro",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "radial", "animated": true, "noise": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 5 }]
          },
          {
            "id": "intro-headline",
            "type": "component",
            "componentName": "AnimatedHeadline",
            "props": { "text": "${headline}", "gradient": true, "glow": true },
            "actions": [{ "start": 0, "end": 5 }]
          }
        ]
      },
      {
        "id": "feature-1",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-f1",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "linear", "animated": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 7 }]
          },
          {
            "id": "f1-mockup",
            "type": "component",
            "componentName": "DeviceMockup",
            "props": { "device": "browser", "src": "${feature1_screenshot}", "shadow": true },
            "actions": [{ "start": 0, "end": 7 }]
          }
        ]
      },
      {
        "id": "feature-2",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-f2",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "linear", "animated": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 7 }]
          },
          {
            "id": "f2-mockup",
            "type": "component",
            "componentName": "DeviceMockup",
            "props": { "device": "browser", "src": "${feature2_screenshot}", "shadow": true },
            "actions": [{ "start": 0, "end": 7 }]
          }
        ]
      },
      {
        "id": "feature-3",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-f3",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "linear", "animated": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 7 }]
          },
          {
            "id": "f3-mockup",
            "type": "component",
            "componentName": "DeviceMockup",
            "props": { "device": "browser", "src": "${feature3_screenshot}", "shadow": true },
            "actions": [{ "start": 0, "end": 7 }]
          }
        ]
      },
      {
        "id": "cta-scene",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-cta",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "radial", "animated": true, "noise": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 5 }]
          },
          {
            "id": "cta-text",
            "type": "component",
            "componentName": "AnimatedHeadline",
            "props": { "text": "${cta}", "gradient": true },
            "actions": [{ "start": 0, "end": 5 }]
          }
        ]
      }
    ]
  }
}
