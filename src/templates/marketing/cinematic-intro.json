{
  "id": "cinematic-intro",
  "name": "Cinematic Intro",
  "description": "Dramatic product intro with spotlight reveal, zoom effects, and split-screen features. Uses effect wrappers for coordinated CSS animations — fadeIn, bounceIn, zoomIn, pulse. Perfect for app launches, keynote-style reveals, and trailer openings.",
  "category": "marketing",
  "aspects": ["16x9", "9x16", "1x1"],
  "duration": 22,
  "theme": "cinematic",
  "slots": [
    { "name": "headline", "type": "text", "label": "Main headline", "required": true, "default": "Introducing" },
    { "name": "productName", "type": "text", "label": "Product name", "required": true, "default": "Your Product" },
    { "name": "tagline", "type": "text", "label": "Tagline", "required": true, "default": "The future starts now." },
    { "name": "screenshot", "type": "image", "label": "Product screenshot", "required": true },
    { "name": "feature1", "type": "text", "label": "Feature 1", "required": true, "default": "Lightning Fast" },
    { "name": "feature1Detail", "type": "text", "label": "Feature 1 detail", "default": "Built for performance" },
    { "name": "feature2", "type": "text", "label": "Feature 2", "required": true, "default": "Beautifully Simple" },
    { "name": "feature2Detail", "type": "text", "label": "Feature 2 detail", "default": "Designed with care" },
    { "name": "stat", "type": "number", "label": "Key metric", "default": 10 },
    { "name": "statSuffix", "type": "text", "label": "Metric suffix", "default": "x" },
    { "name": "statLabel", "type": "text", "label": "Metric label", "default": "faster" },
    { "name": "cta", "type": "text", "label": "Call to action", "required": true, "default": "Get started →" }
  ],
  "streamTree": {
    "id": "root",
    "type": "root",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "theme": "${theme}",
    "isSeries": true,
    "transition": "fade",
    "transitionTime": 0.3,
    "stylesheet": ".effect { overflow: hidden; }",
    "children": [
      {
        "id": "scene-spotlight",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "spot-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true, "noise": true }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          { "id": "spot-reveal", "type": "component", "componentName": "SpotlightReveal", "props": { "x": 50, "y": 50, "maxRadius": 120 }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          {
            "id": "spot-headline-fx",
            "type": "effect",
            "animation": "fadeInDown",
            "animationTimingFunction": "ease-out",
            "children": [
              { "id": "spot-headline", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${headline}", "size": "xl", "glow": true }, "actions": [{ "start": 0.3, "end": 4 }] }
            ],
            "actions": [{ "start": 0.3, "end": 4 }]
          },
          { "id": "spot-particles", "type": "component", "componentName": "ParticleField", "props": { "count": 60, "speed": 0.3 }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] }
        ]
      },
      {
        "id": "scene-reveal",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "rev-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 5 }] },
          { "id": "rev-leak", "type": "component", "componentName": "LightLeak", "props": { "intensity": 1 }, "isBackground": true, "actions": [{ "start": 0, "end": 5 }] },
          {
            "id": "rev-name-fx",
            "type": "effect",
            "animation": "bounceIn",
            "animationTimingFunction": "ease-out",
            "children": [
              { "id": "rev-name", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${productName}", "size": "xxl", "gradient": true, "glow": true }, "actions": [{ "start": 0.2, "end": 5 }] }
            ],
            "actions": [{ "start": 0.2, "end": 5 }]
          },
          {
            "id": "rev-tag-fx",
            "type": "effect",
            "animation": "fadeInUp",
            "animationTimingFunction": "ease-out",
            "children": [
              { "id": "rev-tagline", "type": "component", "componentName": "TypewriterText", "props": { "text": "${tagline}", "speed": 40 }, "actions": [{ "start": 1.5, "end": 5 }] }
            ],
            "actions": [{ "start": 1.5, "end": 5 }]
          },
          { "id": "rev-particles", "type": "component", "componentName": "ParticleField", "props": { "count": 120, "speed": 0.6 }, "isBackground": true, "actions": [{ "start": 0, "end": 5 }] }
        ]
      },
      {
        "id": "scene-device",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "dev-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true, "noise": true }, "isBackground": true, "actions": [{ "start": 0, "end": 5 }] },
          {
            "id": "dev-mockup-fx",
            "type": "effect",
            "animation": "zoomIn",
            "animationTimingFunction": "ease-out",
            "children": [
              { "id": "dev-mockup", "type": "component", "componentName": "DeviceMockup", "props": { "type": "browser", "url": "${screenshot}", "angle": 5 }, "actions": [{ "start": 0.2, "end": 5 }] }
            ],
            "actions": [{ "start": 0.2, "end": 5 }]
          },
          { "id": "dev-leak", "type": "component", "componentName": "LightLeak", "props": { "intensity": 0.6 }, "isBackground": true, "actions": [{ "start": 0, "end": 5 }] }
        ]
      },
      {
        "id": "scene-features",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "feat-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          { "id": "feat-split", "type": "component", "componentName": "SplitScreen", "props": { "direction": "horizontal", "ratio": 0.5, "gap": 24 }, "actions": [{ "start": 0, "end": 4 }] },
          {
            "id": "feat-left-fx",
            "type": "effect",
            "animation": "fadeInLeft",
            "children": [
              { "id": "f1-title", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${feature1}", "size": "lg", "glow": true }, "actions": [{ "start": 0.2, "end": 4 }] },
              { "id": "f1-detail", "type": "component", "componentName": "TypewriterText", "props": { "text": "${feature1Detail}", "speed": 60 }, "actions": [{ "start": 0.8, "end": 4 }] }
            ],
            "actions": [{ "start": 0.2, "end": 4 }]
          },
          {
            "id": "feat-right-fx",
            "type": "effect",
            "animation": "fadeInRight",
            "children": [
              { "id": "f2-title", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${feature2}", "size": "lg", "glow": true }, "actions": [{ "start": 0.2, "end": 4 }] },
              { "id": "f2-detail", "type": "component", "componentName": "TypewriterText", "props": { "text": "${feature2Detail}", "speed": 60 }, "actions": [{ "start": 0.8, "end": 4 }] }
            ],
            "actions": [{ "start": 0.2, "end": 4 }]
          }
        ]
      },
      {
        "id": "scene-cta",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "cta-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true, "noise": true }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          { "id": "cta-particles", "type": "component", "componentName": "ParticleField", "props": { "count": 80, "speed": 0.4 }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          {
            "id": "cta-stat-fx",
            "type": "effect",
            "animation": "pulse",
            "animationIterationCount": 2,
            "children": [
              { "id": "cta-stat", "type": "component", "componentName": "StatCounter", "props": { "value": "${stat}", "suffix": "${statSuffix}", "label": "${statLabel}" }, "actions": [{ "start": 0.3, "end": 4 }] }
            ],
            "actions": [{ "start": 0.3, "end": 4 }]
          },
          {
            "id": "cta-text-fx",
            "type": "effect",
            "animation": "fadeInUp",
            "children": [
              { "id": "cta-text", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${cta}", "size": "xl", "gradient": true }, "actions": [{ "start": 1.5, "end": 4 }] }
            ],
            "actions": [{ "start": 1.5, "end": 4 }]
          },
          { "id": "cta-leak", "type": "component", "componentName": "LightLeak", "props": { "intensity": 0.8 }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] }
        ]
      }
    ]
  }
}
