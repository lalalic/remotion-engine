{
  "id": "glow-up",
  "name": "Glow-Up Reveal",
  "description": "Visual transformation reel. Hook → ComparisonSlider swipe between two images → metric ProgressBars quantify the win → punchline. Use for redesigns, weight-loss, room makeovers, code refactors, dashboard glow-ups.",
  "category": "social",
  "aspects": ["9x16", "1x1", "16x9"],
  "duration": 12,
  "theme": "minimal",
  "slots": [
    { "name": "hook", "type": "text", "label": "Hook line", "required": true, "default": "I rebuilt this in 24 hours" },
    { "name": "beforeImage", "type": "image", "label": "Before image URL", "required": true, "default": "https://placehold.co/1080x1080/333/fff?text=BEFORE" },
    { "name": "afterImage", "type": "image", "label": "After image URL", "required": true, "default": "https://placehold.co/1080x1080/0a84ff/fff?text=AFTER" },
    { "name": "beforeLabel", "type": "text", "label": "Before label", "default": "Before" },
    { "name": "afterLabel", "type": "text", "label": "After label", "default": "After" },
    { "name": "metric1Label", "type": "text", "label": "Metric 1 label", "required": true, "default": "Page weight" },
    { "name": "metric1Value", "type": "number", "label": "Metric 1 % improvement (0-100)", "default": 87 },
    { "name": "metric2Label", "type": "text", "label": "Metric 2 label", "required": true, "default": "Load time" },
    { "name": "metric2Value", "type": "number", "label": "Metric 2 % improvement (0-100)", "default": 76 },
    { "name": "metric3Label", "type": "text", "label": "Metric 3 label", "required": true, "default": "User happiness" },
    { "name": "metric3Value", "type": "number", "label": "Metric 3 % improvement (0-100)", "default": 95 },
    { "name": "punchline", "type": "text", "label": "Closing line", "default": "Worth every late night." }
  ],
  "streamTree": {
    "id": "root",
    "type": "root",
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "theme": "${theme}",
    "isSeries": true,
    "transition": "fade",
    "transitionTime": 0.25,
    "children": [
      {
        "id": "scene-hook",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "hook-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 2 }] },
          { "id": "hook-text", "type": "component", "componentName": "TypewriterText", "props": { "text": "${hook}", "speed": 55 }, "actions": [{ "start": 0, "end": 2 }] }
        ]
      },
      {
        "id": "scene-compare",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "compare-slider", "type": "component", "componentName": "ComparisonSlider", "props": { "before": "${beforeImage}", "after": "${afterImage}", "beforeLabel": "${beforeLabel}", "afterLabel": "${afterLabel}", "dividerStart": 0.1, "dividerEnd": 0.9 }, "actions": [{ "start": 0, "end": 5 }] }
        ]
      },
      {
        "id": "scene-metrics",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "metrics-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 3.5 }] },
          { "id": "metrics-title", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "By the numbers", "size": "lg" }, "actions": [{ "start": 0, "end": 0.8 }] },
          {
            "id": "metrics-bars",
            "type": "component",
            "componentName": "ProgressBar",
            "props": {
              "items": [
                { "label": "${metric1Label}", "value": "${metric1Value}" },
                { "label": "${metric2Label}", "value": "${metric2Value}" },
                { "label": "${metric3Label}", "value": "${metric3Value}" }
              ]
            },
            "actions": [{ "start": 0.8, "end": 3.5 }]
          }
        ]
      },
      {
        "id": "scene-outro",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "outro-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 1.5 }] },
          { "id": "outro-leak", "type": "component", "componentName": "LightLeak", "props": { "intensity": 0.6 }, "isBackground": true, "actions": [{ "start": 0, "end": 1.5 }] },
          { "id": "outro-text", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${punchline}", "size": "xl", "gradient": true, "glow": true }, "actions": [{ "start": 0, "end": 1.5 }] }
        ]
      }
    ]
  }
}
