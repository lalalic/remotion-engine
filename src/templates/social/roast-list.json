{
  "id": "roast-list",
  "name": "Roast List",
  "description": "Fast-cut comedic listicle: 5 things to roast about a target (a framework, a habit, your own old code). Glitch hook → 5 rapid-fire jabs with name + punchline → mic-drop outro. High-energy 9x16 for TikTok / Reels / Shorts.",
  "category": "social",
  "aspects": ["9x16", "1x1"],
  "duration": 22,
  "theme": "neon",
  "slots": [
    { "name": "subject", "type": "text", "label": "Roast target", "required": true, "default": "JavaScript" },
    { "name": "hook", "type": "text", "label": "Hook line", "default": "5 things wrong with…" },
    { "name": "jab1Name", "type": "text", "label": "Jab #1 headline", "required": true, "default": "undefined is not a function" },
    { "name": "jab1Punch", "type": "text", "label": "Jab #1 punchline", "default": "Yeah no kidding it isn't." },
    { "name": "jab2Name", "type": "text", "label": "Jab #2 headline", "required": true, "default": "this" },
    { "name": "jab2Punch", "type": "text", "label": "Jab #2 punchline", "default": "Means seven different things." },
    { "name": "jab3Name", "type": "text", "label": "Jab #3 headline", "required": true, "default": "npm install" },
    { "name": "jab3Punch", "type": "text", "label": "Jab #3 punchline", "default": "Downloads 412MB. For a regex." },
    { "name": "jab4Name", "type": "text", "label": "Jab #4 headline", "required": true, "default": "== vs ===" },
    { "name": "jab4Punch", "type": "text", "label": "Jab #4 punchline", "default": "One lies. The other lies louder." },
    { "name": "jab5Name", "type": "text", "label": "Jab #5 headline", "required": true, "default": "NaN === NaN" },
    { "name": "jab5Punch", "type": "text", "label": "Jab #5 punchline", "default": "Returns false. Therapy required." },
    { "name": "outro", "type": "text", "label": "Mic-drop line", "default": "And yet we ship it. Daily." }
  ],
  "streamTree": {
    "id": "root",
    "type": "root",
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "theme": "${theme}",
    "isSeries": true,
    "transition": "fade",
    "transitionTime": 0.1,
    "children": [
      {
        "id": "scene-hook",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "hook-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true, "noise": true }, "isBackground": true, "actions": [{ "start": 0, "end": 2.5 }] },
          { "id": "hook-leak", "type": "component", "componentName": "LightLeak", "props": { "intensity": 0.9 }, "isBackground": true, "actions": [{ "start": 0, "end": 2.5 }] },
          { "id": "hook-line", "type": "component", "componentName": "GlitchReveal", "props": { "text": "${hook}", "intensity": 0.9 }, "actions": [{ "start": 0, "end": 1 }] },
          { "id": "hook-subject", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${subject}", "size": "xxl", "gradient": true, "glow": true }, "actions": [{ "start": 1, "end": 2.5 }] }
        ]
      },
      {
        "id": "scene-jab1",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "j1-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 3.5 }] },
          { "id": "j1-num", "type": "component", "componentName": "GlitchReveal", "props": { "text": "#1", "intensity": 0.7 }, "actions": [{ "start": 0, "end": 0.6 }] },
          { "id": "j1-name", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${jab1Name}", "size": "xl", "glow": true }, "actions": [{ "start": 0.5, "end": 3.5 }] },
          { "id": "j1-punch", "type": "component", "componentName": "TypewriterText", "props": { "text": "${jab1Punch}", "speed": 80 }, "actions": [{ "start": 1.4, "end": 3.5 }] }
        ]
      },
      {
        "id": "scene-jab2",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "j2-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 3.5 }] },
          { "id": "j2-num", "type": "component", "componentName": "GlitchReveal", "props": { "text": "#2", "intensity": 0.7 }, "actions": [{ "start": 0, "end": 0.6 }] },
          { "id": "j2-name", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${jab2Name}", "size": "xl", "glow": true }, "actions": [{ "start": 0.5, "end": 3.5 }] },
          { "id": "j2-punch", "type": "component", "componentName": "TypewriterText", "props": { "text": "${jab2Punch}", "speed": 80 }, "actions": [{ "start": 1.4, "end": 3.5 }] }
        ]
      },
      {
        "id": "scene-jab3",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "j3-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 3.5 }] },
          { "id": "j3-num", "type": "component", "componentName": "GlitchReveal", "props": { "text": "#3", "intensity": 0.7 }, "actions": [{ "start": 0, "end": 0.6 }] },
          { "id": "j3-name", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${jab3Name}", "size": "xl", "glow": true }, "actions": [{ "start": 0.5, "end": 3.5 }] },
          { "id": "j3-punch", "type": "component", "componentName": "TypewriterText", "props": { "text": "${jab3Punch}", "speed": 80 }, "actions": [{ "start": 1.4, "end": 3.5 }] }
        ]
      },
      {
        "id": "scene-jab4",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "j4-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 3.5 }] },
          { "id": "j4-num", "type": "component", "componentName": "GlitchReveal", "props": { "text": "#4", "intensity": 0.7 }, "actions": [{ "start": 0, "end": 0.6 }] },
          { "id": "j4-name", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${jab4Name}", "size": "xl", "glow": true }, "actions": [{ "start": 0.5, "end": 3.5 }] },
          { "id": "j4-punch", "type": "component", "componentName": "TypewriterText", "props": { "text": "${jab4Punch}", "speed": 80 }, "actions": [{ "start": 1.4, "end": 3.5 }] }
        ]
      },
      {
        "id": "scene-jab5",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "j5-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true, "noise": true }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          { "id": "j5-particles", "type": "component", "componentName": "ParticleField", "props": { "count": 120, "speed": 0.7 }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          { "id": "j5-num", "type": "component", "componentName": "GlitchReveal", "props": { "text": "#5", "intensity": 0.9 }, "actions": [{ "start": 0, "end": 0.6 }] },
          { "id": "j5-name", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${jab5Name}", "size": "xxl", "gradient": true, "glow": true }, "actions": [{ "start": 0.5, "end": 4 }] },
          { "id": "j5-punch", "type": "component", "componentName": "TypewriterText", "props": { "text": "${jab5Punch}", "speed": 80 }, "actions": [{ "start": 1.5, "end": 4 }] }
        ]
      },
      {
        "id": "scene-outro",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "outro-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 2 }] },
          { "id": "outro-leak", "type": "component", "componentName": "LightLeak", "props": { "intensity": 0.8 }, "isBackground": true, "actions": [{ "start": 0, "end": 2 }] },
          { "id": "outro-text", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${outro}", "size": "xxl", "gradient": true, "glow": true }, "actions": [{ "start": 0, "end": 2 }] }
        ]
      }
    ]
  }
}
