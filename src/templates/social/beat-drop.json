{
  "id": "beat-drop",
  "name": "Beat Drop",
  "description": "High-energy music-synced reveal: audio-reactive rhythm stream drives beat timing, with effect wrappers for bounceIn/pulse on each beat. Hook → beat-synced feature cards → climax stat → CTA. Perfect for TikTok, Reels, product drops.",
  "category": "social",
  "aspects": ["9x16", "1x1", "16x9"],
  "duration": 16,
  "theme": "neon",
  "slots": [
    { "name": "hook", "type": "text", "label": "Hook line", "required": true, "default": "Wait for it..." },
    { "name": "bgm", "type": "video", "label": "Background music (audio file)", "required": false, "default": "" },
    { "name": "beat1Text", "type": "text", "label": "Beat 1 text", "required": true, "default": "Fast" },
    { "name": "beat1Image", "type": "image", "label": "Beat 1 image", "required": false },
    { "name": "beat2Text", "type": "text", "label": "Beat 2 text", "required": true, "default": "Simple" },
    { "name": "beat2Image", "type": "image", "label": "Beat 2 image", "required": false },
    { "name": "beat3Text", "type": "text", "label": "Beat 3 text", "required": true, "default": "Powerful" },
    { "name": "beat3Image", "type": "image", "label": "Beat 3 image", "required": false },
    { "name": "beat4Text", "type": "text", "label": "Beat 4 text", "required": true, "default": "Free" },
    { "name": "beat4Image", "type": "image", "label": "Beat 4 image", "required": false },
    { "name": "stat", "type": "number", "label": "Big number", "default": 100 },
    { "name": "statSuffix", "type": "text", "label": "Number suffix", "default": "K+" },
    { "name": "statLabel", "type": "text", "label": "Number label", "default": "users" },
    { "name": "cta", "type": "text", "label": "Call to action", "required": true, "default": "Try it now →" }
  ],
  "streamTree": {
    "id": "root",
    "type": "root",
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "theme": "${theme}",
    "isSeries": true,
    "transition": "fade",
    "transitionTime": 0.15,
    "stylesheet": ".effect { overflow: hidden; }",
    "children": [
      {
        "id": "scene-hook",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "hook-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true, "noise": true }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          { "id": "hook-particles", "type": "component", "componentName": "ParticleField", "props": { "count": 150, "speed": 0.8 }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          {
            "id": "hook-fx",
            "type": "effect",
            "animation": "pulse",
            "animationIterationCount": 3,
            "children": [
              { "id": "hook-text", "type": "component", "componentName": "GlitchReveal", "props": { "text": "${hook}", "intensity": 1.0 }, "actions": [{ "start": 0.2, "end": 3 }] }
            ],
            "actions": [{ "start": 0.2, "end": 3 }]
          }
        ]
      },
      {
        "id": "scene-beats",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "beats-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 8 }] },
          { "id": "beats-leak", "type": "component", "componentName": "LightLeak", "props": { "intensity": 0.9 }, "isBackground": true, "actions": [{ "start": 0, "end": 8 }] },
          {
            "id": "beats-rhythm",
            "type": "rhythm",
            "src": "${bgm}",
            "volume": 0.8,
            "spots": [0.5, 2.5, 4.5, 6.5],
            "children": [],
            "actions": [{ "start": 0, "end": 8 }]
          },
          {
            "id": "beat1-fx",
            "type": "effect",
            "animation": "bounceIn",
            "children": [
              { "id": "b1-text", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${beat1Text}", "size": "xxl", "gradient": true, "glow": true }, "actions": [{ "start": 0.5, "end": 2.5 }] }
            ],
            "actions": [{ "start": 0.5, "end": 2.5 }]
          },
          {
            "id": "beat2-fx",
            "type": "effect",
            "animation": "bounceIn",
            "children": [
              { "id": "b2-text", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${beat2Text}", "size": "xxl", "gradient": true, "glow": true }, "actions": [{ "start": 2.5, "end": 4.5 }] }
            ],
            "actions": [{ "start": 2.5, "end": 4.5 }]
          },
          {
            "id": "beat3-fx",
            "type": "effect",
            "animation": "bounceIn",
            "children": [
              { "id": "b3-text", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${beat3Text}", "size": "xxl", "gradient": true, "glow": true }, "actions": [{ "start": 4.5, "end": 6.5 }] }
            ],
            "actions": [{ "start": 4.5, "end": 6.5 }]
          },
          {
            "id": "beat4-fx",
            "type": "effect",
            "animation": "bounceIn",
            "children": [
              { "id": "b4-text", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${beat4Text}", "size": "xxl", "gradient": true, "glow": true }, "actions": [{ "start": 6.5, "end": 8 }] }
            ],
            "actions": [{ "start": 6.5, "end": 8 }]
          }
        ]
      },
      {
        "id": "scene-climax",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "clx-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true, "noise": true }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          { "id": "clx-particles", "type": "component", "componentName": "ParticleField", "props": { "count": 200, "speed": 1.2 }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          {
            "id": "clx-stat-fx",
            "type": "effect",
            "animation": "heartBeat",
            "animationIterationCount": 2,
            "children": [
              { "id": "clx-stat", "type": "component", "componentName": "StatCounter", "props": { "value": "${stat}", "suffix": "${statSuffix}", "label": "${statLabel}" }, "actions": [{ "start": 0.3, "end": 3 }] }
            ],
            "actions": [{ "start": 0.3, "end": 3 }]
          },
          { "id": "clx-leak", "type": "component", "componentName": "LightLeak", "props": { "intensity": 1.0 }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] }
        ]
      },
      {
        "id": "scene-cta",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "cta-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 2 }] },
          {
            "id": "cta-fx",
            "type": "effect",
            "animation": "rubberBand",
            "children": [
              { "id": "cta-text", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${cta}", "size": "xl", "gradient": true }, "actions": [{ "start": 0.2, "end": 2 }] }
            ],
            "actions": [{ "start": 0.2, "end": 2 }]
          },
          { "id": "cta-particles", "type": "component", "componentName": "ParticleField", "props": { "count": 100, "speed": 0.5 }, "isBackground": true, "actions": [{ "start": 0, "end": 2 }] }
        ]
      }
    ]
  }
}
