{
  "id": "announcement",
  "name": "Announcement Drop",
  "description": "High-energy product / news announcement. Countdown glitch hook → name reveal with tagline → three feature highlights → CTA. Use for launches, releases, fundraising rounds, hiring announcements.",
  "category": "social",
  "aspects": ["16x9", "9x16", "1x1"],
  "duration": 14,
  "theme": "cinematic",
  "slots": [
    { "name": "kicker", "type": "text", "label": "Hook line", "required": true, "default": "Something new" },
    { "name": "productName", "type": "text", "label": "Product / project name", "required": true, "default": "Launching X" },
    { "name": "tagline", "type": "text", "label": "Tagline", "required": true, "default": "The fastest way to ship." },
    { "name": "feature1", "type": "text", "label": "Feature 1", "required": true, "default": "Blazing fast" },
    { "name": "feature1Detail", "type": "text", "label": "Feature 1 detail", "default": "100x quicker than before" },
    { "name": "feature2", "type": "text", "label": "Feature 2", "required": true, "default": "Zero config" },
    { "name": "feature2Detail", "type": "text", "label": "Feature 2 detail", "default": "Works out of the box" },
    { "name": "feature3", "type": "text", "label": "Feature 3", "required": true, "default": "Open source" },
    { "name": "feature3Detail", "type": "text", "label": "Feature 3 detail", "default": "MIT licensed, forever free" },
    { "name": "cta", "type": "text", "label": "Call to action", "required": true, "default": "Try it today →" }
  ],
  "streamTree": {
    "id": "root",
    "type": "root",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "theme": "${theme}",
    "isSeries": true,
    "transition": "fade",
    "transitionTime": 0.2,
    "children": [
      {
        "id": "scene-hook",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "hook-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true, "noise": true }, "isBackground": true, "actions": [{ "start": 0, "end": 2 }] },
          { "id": "hook-leak", "type": "component", "componentName": "LightLeak", "props": { "intensity": 0.8 }, "isBackground": true, "actions": [{ "start": 0, "end": 2 }] },
          { "id": "hook-text", "type": "component", "componentName": "GlitchReveal", "props": { "text": "${kicker}", "intensity": 0.9 }, "actions": [{ "start": 0.1, "end": 2 }] }
        ]
      },
      {
        "id": "scene-name",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "name-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          { "id": "name-particles", "type": "component", "componentName": "ParticleField", "props": { "count": 100, "speed": 0.5 }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          { "id": "name-title", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${productName}", "size": "xxl", "gradient": true, "glow": true }, "actions": [{ "start": 0.2, "end": 3 }] },
          { "id": "name-tagline", "type": "component", "componentName": "TypewriterText", "props": { "text": "${tagline}", "speed": 50 }, "actions": [{ "start": 1.5, "end": 3 }] }
        ]
      },
      {
        "id": "scene-f1",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "f1-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 2.5 }] },
          { "id": "f1-title", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${feature1}", "size": "xl", "glow": true }, "actions": [{ "start": 0, "end": 2.5 }] },
          { "id": "f1-detail", "type": "component", "componentName": "TypewriterText", "props": { "text": "${feature1Detail}", "speed": 70 }, "actions": [{ "start": 0.6, "end": 2.5 }] }
        ]
      },
      {
        "id": "scene-f2",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "f2-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 2.5 }] },
          { "id": "f2-title", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${feature2}", "size": "xl", "glow": true }, "actions": [{ "start": 0, "end": 2.5 }] },
          { "id": "f2-detail", "type": "component", "componentName": "TypewriterText", "props": { "text": "${feature2Detail}", "speed": 70 }, "actions": [{ "start": 0.6, "end": 2.5 }] }
        ]
      },
      {
        "id": "scene-f3",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "f3-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 2.5 }] },
          { "id": "f3-title", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${feature3}", "size": "xl", "glow": true }, "actions": [{ "start": 0, "end": 2.5 }] },
          { "id": "f3-detail", "type": "component", "componentName": "TypewriterText", "props": { "text": "${feature3Detail}", "speed": 70 }, "actions": [{ "start": 0.6, "end": 2.5 }] }
        ]
      },
      {
        "id": "scene-cta",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "cta-bg", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 1.5 }] },
          { "id": "cta-particles", "type": "component", "componentName": "ParticleField", "props": { "count": 150, "speed": 0.7 }, "isBackground": true, "actions": [{ "start": 0, "end": 1.5 }] },
          { "id": "cta-leak", "type": "component", "componentName": "LightLeak", "props": { "intensity": 0.9 }, "isBackground": true, "actions": [{ "start": 0, "end": 1.5 }] },
          { "id": "cta-text", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${cta}", "size": "xxl", "gradient": true, "glow": true }, "actions": [{ "start": 0, "end": 1.5 }] }
        ]
      }
    ]
  }
}
