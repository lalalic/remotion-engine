{
  "id": "year-recap",
  "name": "Year Recap",
  "description": "GitHub-Unwrapped style year-in-review with a 4-stat grid. Hooks with the year, slams 4 milestone numbers one by one, ends with a personalized thank-you. Works for product, creator, or personal wrapped.",
  "category": "personal",
  "aspects": ["9x16", "1x1", "16x9"],
  "duration": 18,
  "theme": "cinematic",
  "slots": [
    { "name": "year", "type": "text", "label": "Year / period label", "required": true, "default": "2025" },
    { "name": "owner", "type": "text", "label": "Who this is for", "required": true, "default": "@username" },
    { "name": "stat1Value", "type": "number", "label": "Stat 1 value", "required": true, "default": 412 },
    { "name": "stat1Label", "type": "text", "label": "Stat 1 label", "required": true, "default": "commits" },
    { "name": "stat1Suffix", "type": "text", "label": "Stat 1 suffix", "default": "" },
    { "name": "stat2Value", "type": "number", "label": "Stat 2 value", "required": true, "default": 28 },
    { "name": "stat2Label", "type": "text", "label": "Stat 2 label", "required": true, "default": "PRs merged" },
    { "name": "stat2Suffix", "type": "text", "label": "Stat 2 suffix", "default": "" },
    { "name": "stat3Value", "type": "number", "label": "Stat 3 value", "required": true, "default": 1240 },
    { "name": "stat3Label", "type": "text", "label": "Stat 3 label", "required": true, "default": "stars earned" },
    { "name": "stat3Suffix", "type": "text", "label": "Stat 3 suffix", "default": "" },
    { "name": "stat4Value", "type": "number", "label": "Stat 4 value", "required": true, "default": 7 },
    { "name": "stat4Label", "type": "text", "label": "Stat 4 label", "required": true, "default": "shipped projects" },
    { "name": "stat4Suffix", "type": "text", "label": "Stat 4 suffix", "default": "" },
    { "name": "closingLine", "type": "text", "label": "Closing line", "default": "Onto the next chapter." }
  ],
  "streamTree": {
    "id": "root",
    "type": "root",
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "theme": "${theme}",
    "isSeries": true,
    "transition": "fade",
    "transitionTime": 0.4,
    "children": [
      {
        "id": "scene-intro",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "bgi", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true, "noise": true }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          { "id": "parti", "type": "component", "componentName": "ParticleField", "props": { "count": 60, "speed": 0.4 }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          { "id": "year-text", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${year}", "subtext": "${owner} — your year, in numbers", "gradient": true, "glow": true, "size": "xxl" }, "actions": [{ "start": 0, "end": 3 }] }
        ]
      },
      {
        "id": "scene-s1",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "bg1", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          { "id": "leak1", "type": "component", "componentName": "LightLeak", "props": { "intensity": 0.5 }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          { "id": "stat1", "type": "component", "componentName": "StatCounter", "props": { "value": "${stat1Value}", "suffix": "${stat1Suffix}", "label": "${stat1Label}", "size": "xl" }, "actions": [{ "start": 0, "end": 3 }] }
        ]
      },
      {
        "id": "scene-s2",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "bg2", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          { "id": "leak2", "type": "component", "componentName": "LightLeak", "props": { "intensity": 0.5 }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          { "id": "stat2", "type": "component", "componentName": "StatCounter", "props": { "value": "${stat2Value}", "suffix": "${stat2Suffix}", "label": "${stat2Label}", "size": "xl" }, "actions": [{ "start": 0, "end": 3 }] }
        ]
      },
      {
        "id": "scene-s3",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "bg3", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          { "id": "leak3", "type": "component", "componentName": "LightLeak", "props": { "intensity": 0.6 }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          { "id": "stat3", "type": "component", "componentName": "StatCounter", "props": { "value": "${stat3Value}", "suffix": "${stat3Suffix}", "label": "${stat3Label}", "size": "xl" }, "actions": [{ "start": 0, "end": 3 }] }
        ]
      },
      {
        "id": "scene-s4",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "bg4", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          { "id": "parts4", "type": "component", "componentName": "ParticleField", "props": { "count": 100, "speed": 0.7 }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          { "id": "stat4", "type": "component", "componentName": "StatCounter", "props": { "value": "${stat4Value}", "suffix": "${stat4Suffix}", "label": "${stat4Label}", "size": "xxl", "highlight": true }, "actions": [{ "start": 0, "end": 3 }] }
        ]
      },
      {
        "id": "scene-close",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "bgc", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          { "id": "leakc", "type": "component", "componentName": "LightLeak", "props": { "intensity": 0.7 }, "isBackground": true, "actions": [{ "start": 0, "end": 3 }] },
          { "id": "close-text", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${closingLine}", "subtext": "${owner}", "gradient": true, "glow": true }, "actions": [{ "start": 0, "end": 3 }] }
        ]
      }
    ]
  }
}
