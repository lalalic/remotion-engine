{
  "id": "top5-countdown",
  "name": "Top 5 Countdown",
  "description": "Classic TikTok/YouTube countdown format: '#5 → #1' reveal list. Each rank gets its own beat with glitch reveal, image, and one-liner. Hooks at the start, lands the #1 with confetti at the end.",
  "category": "social",
  "aspects": ["9x16", "16x9", "1x1"],
  "duration": 28,
  "theme": "cinematic",
  "slots": [
    { "name": "category", "type": "text", "label": "Topic", "required": true, "default": "Best dev tools of 2025" },
    { "name": "item5Name", "type": "text", "label": "#5 name", "required": true, "default": "Item 5" },
    { "name": "item5Tag", "type": "text", "label": "#5 tagline", "default": "Honorable mention." },
    { "name": "item5Image", "type": "image", "label": "#5 image", "default": "" },
    { "name": "item4Name", "type": "text", "label": "#4 name", "required": true, "default": "Item 4" },
    { "name": "item4Tag", "type": "text", "label": "#4 tagline", "default": "Quiet workhorse." },
    { "name": "item4Image", "type": "image", "label": "#4 image", "default": "" },
    { "name": "item3Name", "type": "text", "label": "#3 name", "required": true, "default": "Item 3" },
    { "name": "item3Tag", "type": "text", "label": "#3 tagline", "default": "Surprisingly fun." },
    { "name": "item3Image", "type": "image", "label": "#3 image", "default": "" },
    { "name": "item2Name", "type": "text", "label": "#2 name", "required": true, "default": "Item 2" },
    { "name": "item2Tag", "type": "text", "label": "#2 tagline", "default": "Almost the top." },
    { "name": "item2Image", "type": "image", "label": "#2 image", "default": "" },
    { "name": "item1Name", "type": "text", "label": "#1 name", "required": true, "default": "Item 1" },
    { "name": "item1Tag", "type": "text", "label": "#1 tagline", "default": "The winner." },
    { "name": "item1Image", "type": "image", "label": "#1 image", "default": "" }
  ],
  "streamTree": {
    "id": "root",
    "type": "root",
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "theme": "${theme}",
    "isSeries": true,
    "transition": "slide",
    "transitionTime": 0.35,
    "children": [
      {
        "id": "scene-hook",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-hook",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "radial", "animated": true, "noise": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 3 }]
          },
          {
            "id": "hook-particles",
            "type": "component",
            "componentName": "ParticleField",
            "props": { "count": 40 },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 3 }]
          },
          {
            "id": "hook-text",
            "type": "component",
            "componentName": "AnimatedHeadline",
            "props": { "text": "TOP 5", "subtext": "${category}", "gradient": true, "glow": true, "size": "xl" },
            "actions": [{ "start": 0, "end": 3 }]
          }
        ]
      },
      {
        "id": "scene-5",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "bg5", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          { "id": "rank5", "type": "component", "componentName": "GlitchReveal", "props": { "text": "#5", "intensity": 0.8, "size": "xl" }, "actions": [{ "start": 0, "end": 1.2 }] },
          { "id": "name5", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${item5Name}", "subtext": "${item5Tag}" }, "actions": [{ "start": 1, "end": 4 }] },
          { "id": "img5", "type": "image", "src": "${item5Image}", "actions": [{ "start": 1.2, "end": 4 }] }
        ]
      },
      {
        "id": "scene-4",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "bg4", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          { "id": "rank4", "type": "component", "componentName": "GlitchReveal", "props": { "text": "#4", "intensity": 0.8, "size": "xl" }, "actions": [{ "start": 0, "end": 1.2 }] },
          { "id": "name4", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${item4Name}", "subtext": "${item4Tag}" }, "actions": [{ "start": 1, "end": 4 }] },
          { "id": "img4", "type": "image", "src": "${item4Image}", "actions": [{ "start": 1.2, "end": 4 }] }
        ]
      },
      {
        "id": "scene-3",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "bg3", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          { "id": "rank3", "type": "component", "componentName": "GlitchReveal", "props": { "text": "#3", "intensity": 0.9, "size": "xl" }, "actions": [{ "start": 0, "end": 1.2 }] },
          { "id": "name3", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${item3Name}", "subtext": "${item3Tag}" }, "actions": [{ "start": 1, "end": 4 }] },
          { "id": "img3", "type": "image", "src": "${item3Image}", "actions": [{ "start": 1.2, "end": 4 }] }
        ]
      },
      {
        "id": "scene-2",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "bg2", "type": "component", "componentName": "GradientBackground", "props": { "type": "linear", "animated": true }, "isBackground": true, "actions": [{ "start": 0, "end": 4 }] },
          { "id": "rank2", "type": "component", "componentName": "GlitchReveal", "props": { "text": "#2", "intensity": 1.0, "size": "xl" }, "actions": [{ "start": 0, "end": 1.2 }] },
          { "id": "name2", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${item2Name}", "subtext": "${item2Tag}" }, "actions": [{ "start": 1, "end": 4 }] },
          { "id": "img2", "type": "image", "src": "${item2Image}", "actions": [{ "start": 1.2, "end": 4 }] }
        ]
      },
      {
        "id": "scene-1",
        "type": "folder",
        "isSeries": false,
        "children": [
          { "id": "bg1", "type": "component", "componentName": "GradientBackground", "props": { "type": "radial", "animated": true, "noise": true }, "isBackground": true, "actions": [{ "start": 0, "end": 6 }] },
          { "id": "particles1", "type": "component", "componentName": "ParticleField", "props": { "count": 150, "speed": 0.8 }, "isBackground": true, "actions": [{ "start": 0, "end": 6 }] },
          { "id": "leak1", "type": "component", "componentName": "LightLeak", "props": { "intensity": 0.9 }, "isBackground": true, "actions": [{ "start": 0, "end": 6 }] },
          { "id": "rank1", "type": "component", "componentName": "GlitchReveal", "props": { "text": "#1", "intensity": 1.0, "size": "xxl" }, "actions": [{ "start": 0, "end": 1.5 }] },
          { "id": "name1", "type": "component", "componentName": "AnimatedHeadline", "props": { "text": "${item1Name}", "subtext": "${item1Tag}", "gradient": true, "glow": true, "size": "xl" }, "actions": [{ "start": 1.2, "end": 6 }] },
          { "id": "img1", "type": "image", "src": "${item1Image}", "actions": [{ "start": 1.5, "end": 6 }] }
        ]
      }
    ]
  }
}
