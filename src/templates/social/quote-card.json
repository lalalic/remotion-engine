{
  "id": "quote-card",
  "name": "Quote Card",
  "description": "Animated pull-quote card with author attribution — great for sharing wisdom, testimonials, or punchy lines on X, Threads, LinkedIn. Quote types in with a typewriter feel, author fades in after.",
  "category": "social",
  "aspects": ["1x1", "9x16", "16x9"],
  "duration": 8,
  "theme": "editorial",
  "slots": [
    { "name": "quote", "type": "text", "label": "The quote", "required": true, "default": "Talk is cheap. Show me the code." },
    { "name": "author", "type": "text", "label": "Author", "required": true, "default": "Linus Torvalds" },
    { "name": "authorTitle", "type": "text", "label": "Author title / handle", "default": "Creator of Linux" },
    { "name": "accent", "type": "text", "label": "Accent label (top)", "default": "QUOTE OF THE DAY" }
  ],
  "streamTree": {
    "id": "root",
    "type": "root",
    "width": 1080,
    "height": 1080,
    "fps": 30,
    "theme": "${theme}",
    "isSeries": true,
    "transition": "fade",
    "transitionTime": 0.25,
    "children": [
      {
        "id": "card",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "linear", "animated": false, "noise": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 8 }]
          },
          {
            "id": "leak",
            "type": "component",
            "componentName": "LightLeak",
            "props": { "intensity": 0.3 },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 8 }]
          },
          {
            "id": "accent",
            "type": "component",
            "componentName": "TypewriterText",
            "props": { "text": "${accent}", "speed": 80, "size": "sm", "color": "#888" },
            "actions": [{ "start": 0, "end": 8 }]
          },
          {
            "id": "quote-body",
            "type": "component",
            "componentName": "TypewriterText",
            "props": { "text": "${quote}", "speed": 22, "size": "xl", "quote": true },
            "actions": [{ "start": 0.5, "end": 7.5 }]
          },
          {
            "id": "author-line",
            "type": "component",
            "componentName": "AnimatedHeadline",
            "props": { "text": "— ${author}", "subtext": "${authorTitle}", "align": "right", "size": "md" },
            "actions": [{ "start": 5, "end": 8 }]
          }
        ]
      }
    ]
  }
}
