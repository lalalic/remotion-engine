{
  "id": "stat-reveal",
  "name": "Stat Reveal",
  "description": "Single huge number celebration — perfect for milestones (1M users, 10K stars, $100K raised). Hooks with a teaser, slams the number with particles, lands the callout.",
  "category": "social",
  "aspects": ["9x16", "1x1", "16x9"],
  "duration": 10,
  "theme": "cinematic",
  "slots": [
    { "name": "teaser", "type": "text", "label": "Teaser line", "required": true, "default": "We just hit…" },
    { "name": "statValue", "type": "number", "label": "Big number", "required": true, "default": 1000000 },
    { "name": "statPrefix", "type": "text", "label": "Number prefix", "default": "" },
    { "name": "statSuffix", "type": "text", "label": "Number suffix", "default": "+" },
    { "name": "statLabel", "type": "text", "label": "What it counts", "required": true, "default": "users" },
    { "name": "callout", "type": "text", "label": "Closing line", "default": "Thank you 💜" }
  ],
  "streamTree": {
    "id": "root",
    "type": "root",
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "theme": "${theme}",
    "isSeries": true,
    "transition": "fade",
    "transitionTime": 0.3,
    "children": [
      {
        "id": "scene-teaser",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-teaser",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "radial", "animated": true, "noise": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 3 }]
          },
          {
            "id": "teaser-text",
            "type": "component",
            "componentName": "TypewriterText",
            "props": { "text": "${teaser}", "speed": 60 },
            "actions": [{ "start": 0, "end": 3 }]
          }
        ]
      },
      {
        "id": "scene-stat",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-stat",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "radial", "animated": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 5 }]
          },
          {
            "id": "stat-particles",
            "type": "component",
            "componentName": "ParticleField",
            "props": { "count": 120, "speed": 0.6 },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 5 }]
          },
          {
            "id": "stat-leak",
            "type": "component",
            "componentName": "LightLeak",
            "props": { "intensity": 0.7 },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 5 }]
          },
          {
            "id": "big-number",
            "type": "component",
            "componentName": "StatCounter",
            "props": {
              "value": "${statValue}",
              "prefix": "${statPrefix}",
              "suffix": "${statSuffix}",
              "label": "${statLabel}",
              "size": "xl"
            },
            "actions": [{ "start": 0.2, "end": 5 }]
          }
        ]
      },
      {
        "id": "scene-callout",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-callout",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "linear", "animated": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 2 }]
          },
          {
            "id": "callout-text",
            "type": "component",
            "componentName": "AnimatedHeadline",
            "props": { "text": "${callout}", "gradient": true, "glow": true },
            "actions": [{ "start": 0, "end": 2 }]
          }
        ]
      }
    ]
  }
}
