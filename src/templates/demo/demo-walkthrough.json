{
  "id": "demo-walkthrough",
  "name": "Demo Walkthrough",
  "description": "Screen recording walkthrough with cursor and annotations",
  "category": "demo",
  "aspects": ["16x9"],
  "duration": 28,
  "theme": "cinematic",
  "slots": [
    { "name": "headline", "type": "text", "label": "Intro headline", "required": true },
    { "name": "screenshot", "type": "image", "label": "App screenshot", "required": true },
    { "name": "step1_annotation", "type": "text", "label": "Step 1 text", "default": "Step 1" },
    { "name": "step1_x", "type": "number", "label": "Step 1 cursor X (%)", "default": 30 },
    { "name": "step1_y", "type": "number", "label": "Step 1 cursor Y (%)", "default": 40 },
    { "name": "step2_annotation", "type": "text", "label": "Step 2 text", "default": "Step 2" },
    { "name": "step2_x", "type": "number", "label": "Step 2 cursor X (%)", "default": 60 },
    { "name": "step2_y", "type": "number", "label": "Step 2 cursor Y (%)", "default": 50 },
    { "name": "step3_annotation", "type": "text", "label": "Step 3 text", "default": "Step 3" },
    { "name": "step3_x", "type": "number", "label": "Step 3 cursor X (%)", "default": 50 },
    { "name": "step3_y", "type": "number", "label": "Step 3 cursor Y (%)", "default": 70 },
    { "name": "cta", "type": "text", "label": "Call to action", "default": "Try it yourself" }
  ],
  "streamTree": {
    "id": "root",
    "type": "root",
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "isSeries": true,
    "transition": "wipe",
    "transitionTime": 0.4,
    "children": [
      {
        "id": "intro",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-intro",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "radial", "animated": true, "noise": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 4 }]
          },
          {
            "id": "intro-text",
            "type": "component",
            "componentName": "AnimatedHeadline",
            "props": { "text": "${headline}", "gradient": true, "glow": true },
            "actions": [{ "start": 0, "end": 4 }]
          }
        ]
      },
      {
        "id": "demo",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-demo",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "linear", "animated": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 20 }]
          },
          {
            "id": "flyover",
            "type": "component",
            "componentName": "CursorFlyover",
            "props": {
              "src": "${screenshot}",
              "steps": [
                {
                  "region": { "x": 0, "y": 0, "zoom": 1.2 },
                  "cursor": { "x": "${step1_x}", "y": "${step1_y}" },
                  "annotation": "${step1_annotation}",
                  "duration": 6
                },
                {
                  "region": { "x": 10, "y": 10, "zoom": 1.5 },
                  "cursor": { "x": "${step2_x}", "y": "${step2_y}" },
                  "annotation": "${step2_annotation}",
                  "duration": 7
                },
                {
                  "region": { "x": 0, "y": 20, "zoom": 1.3 },
                  "cursor": { "x": "${step3_x}", "y": "${step3_y}" },
                  "annotation": "${step3_annotation}",
                  "duration": 7
                }
              ]
            },
            "actions": [{ "start": 0, "end": 20 }]
          }
        ]
      },
      {
        "id": "cta",
        "type": "folder",
        "isSeries": false,
        "children": [
          {
            "id": "bg-cta",
            "type": "component",
            "componentName": "GradientBackground",
            "props": { "type": "radial", "animated": true, "noise": true },
            "isBackground": true,
            "actions": [{ "start": 0, "end": 4 }]
          },
          {
            "id": "cta-text",
            "type": "component",
            "componentName": "AnimatedHeadline",
            "props": { "text": "${cta}", "gradient": true },
            "actions": [{ "start": 0, "end": 4 }]
          }
        ]
      }
    ]
  }
}
