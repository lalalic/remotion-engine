{
  "id": "root",
  "type": "root",
  "width": 1080,
  "height": 1920,
  "fps": 30,
  "theme": "cinematic",
  "isSeries": true,
  "transition": "fade",
  "transitionTime": 0.5,
  "stylesheet": ".caption { background: rgba(0,0,0,0.3); padding: 16px 32px; border-radius: 16px; } .word-active { color: #f97316; }",
  "children": [
    {
      "id": "scene-1",
      "type": "folder",
      "isSeries": false,
      "children": [
        {
          "id": "bg1",
          "type": "component",
          "componentName": "GradientBackground",
          "props": { "type": "radial", "animated": true, "noise": true },
          "isBackground": true,
          "actions": [{ "start": 0, "end": 5 }]
        },
        {
          "id": "title",
          "type": "component",
          "componentName": "AnimatedHeadline",
          "props": { "text": "Hello Remotion", "subtext": "Edit me in the JSON", "gradient": true, "glow": true },
          "actions": [{ "start": 0.5, "end": 4.5 }]
        }
      ]
    },
    {
      "id": "scene-2",
      "type": "folder",
      "isSeries": false,
      "children": [
        {
          "id": "bg2",
          "type": "component",
          "componentName": "GradientBackground",
          "props": { "type": "linear", "animated": true },
          "isBackground": true,
          "actions": [{ "start": 0, "end": 5 }]
        },
        {
          "id": "subtitle-text",
          "type": "subtitle",
          "src": "This text is styled with CSS",
          "style": "color: #ffffff; font-size: 48px; font-weight: bold; text-shadow: 0 2px 12px rgba(0,0,0,0.8);",
          "fontSize": 52,
          "actions": [{ "start": 0.5, "end": 4.5 }]
        }
      ]
    },
    {
      "id": "scene-3",
      "type": "folder",
      "isSeries": false,
      "children": [
        {
          "id": "bg3",
          "type": "component",
          "componentName": "GradientBackground",
          "props": { "type": "radial", "animated": true },
          "isBackground": true,
          "actions": [{ "start": 0, "end": 6 }]
        },
        {
          "id": "particles",
          "type": "component",
          "componentName": "ParticleField",
          "props": { "count": 60, "speed": 0.5 },
          "isBackground": true,
          "actions": [{ "start": 0, "end": 6 }]
        },
        {
          "id": "stats",
          "type": "component",
          "componentName": "StatCounter",
          "props": { "value": 100, "suffix": "%", "label": "automated" },
          "actions": [{ "start": 1, "end": 5 }]
        }
      ]
    },
    {
      "id": "scene-4",
      "type": "folder",
      "isSeries": false,
      "children": [
        {
          "id": "bg4",
          "type": "component",
          "componentName": "GradientBackground",
          "props": { "type": "linear", "animated": true, "noise": true },
          "isBackground": true,
          "actions": [{ "start": 0, "end": 5 }]
        },
        {
          "id": "cta",
          "type": "component",
          "componentName": "AnimatedHeadline",
          "props": { "text": "Ready to ship?", "gradient": true, "glow": true, "split": "char" },
          "actions": [{ "start": 0.5, "end": 4.5 }]
        }
      ]
    }
  ]
}
