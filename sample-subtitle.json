{
  "id": "root",
  "type": "root",
  "width": 1080,
  "height": 1920,
  "fps": 30,
  "isSeries": true,
  "transition": "fade",
  "transitionTime": 0.4,
  "theme": "cinematic",
  "stylesheet": ".caption { background: rgba(0,0,0,0.4); padding: 12px 24px; border-radius: 12px; } .caption .word-active { color: #f97316; } .intro { font-size: 72px; font-weight: 900; } .body { font-size: 48px; font-weight: 600; } .karaoke-caption .word-active { color: #00ff88; transform: scale(1.1); }",
  "children": [
    {
      "id": "scene-1",
      "type": "folder",
      "isSeries": false,
      "children": [
        {
          "id": "bg1",
          "type": "image",
          "src": "https://picsum.photos/seed/sub1/1080/1920",
          "fit": "cover",
          "actions": [{ "start": 0, "end": 4 }]
        },
        {
          "id": "title-caption",
          "type": "subtitle",
          "src": "Hello from Remotion Engine",
          "fontSize": 64,
          "style": "color: #ffffff; text-shadow: 0 4px 20px rgba(0,0,0,0.8); font-weight: bold;",
          "actions": [{ "start": 0.5, "end": 3.5 }]
        }
      ]
    },
    {
      "id": "scene-2",
      "type": "folder",
      "isSeries": false,
      "children": [
        {
          "id": "bg2",
          "type": "image",
